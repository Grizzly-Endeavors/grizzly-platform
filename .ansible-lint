# ansible-lint configuration for lab-iac
# Reference: https://ansible.readthedocs.io/projects/lint/configuring/

# Profile determines severity levels (min, basic, moderate, safety, shared, production)
profile: moderate

# Paths to exclude from linting. ansible-lint's project-root directory walk
# (needed for role/kind discovery) scans the whole repo regardless of which
# files a caller (e.g. the pre-commit hook, scoped to `files: ^ansible/`)
# explicitly passes it, so every non-Ansible top-level dir has to be excluded
# here too — otherwise it also lints Kubernetes manifests, Flux-generated
# bundles, etc. as if they were Ansible content (issue #52).
exclude_paths:
  - archive/
  - .git/
  - .cache/
  - .venv/
  - assets/
  - configs/
  - docker/
  - docs/
  - kubernetes/
  - scripts/

# Rules to skip entirely
skip_list:
  # Allow hyphenated role names (k8s-containerd, r730xd-zfs, monitoring-base, etc.)
  - role-name

  # Allow handlers in playbooks (we define handlers inline in some playbooks)
  - no-handler

  # Allow shell modules where needed (some tasks require shell features)
  # Note: Still prefer command module where possible
  # - command-instead-of-shell

# Rules to warn about (not fail)
warn_list:
  # Warn but don't fail on these
  - name[missing]
  - name[casing]
  - yaml[line-length]
  - command-instead-of-shell
  - risky-shell-pipe

# Enable optional rules
enable_list:
  - empty-string-compare
  - no-log-password
  - no-same-owner

# Ansible-lint should use the yamllint config
use_default_rules: true

# Mock modules that might not be installed or not resolved by lint
mock_modules:
  - ansible.utils.ipaddr
  - ansible.posix.authorized_key
  - ansible.posix.mount
  - community.general.parted
  - community.general.capabilities
  - community.general.filesystem
  - community.crypto.openssh_keypair

# Mock roles that might not be available
mock_roles: []

# Offline mode - don't download dependencies
offline: false

# yaml[line-length] is in warn_list above — no rule-specific overrides needed
