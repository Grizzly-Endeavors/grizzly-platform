# Example app CI: build → GATE → deploy. Copy into an app repo as
# .github/workflows/deploy.yml and adjust the build/deploy steps for the stack.
#
# The gate job calls the centrally-owned reusable workflow. The deploy job runs
# ONLY if the gate passed (and therefore signed the image) — so an unsigned
# image never reaches the cluster, and Kyverno would refuse it anyway.
#
# PREREQUISITE: this repo must contain a root `gate-config.json` honestly mapping
# its projects, e.g.  { "version": 1, "projects": [ { "language": "rust", "path": "." } ] }
# The gate (>= v0.3.0) fails closed without it, and on any undeclared or
# unsupported code. See https://github.com/Grizzly-Endeavors/grizzly-gate#declaring-the-repo-gate-configjson.

name: Build and Deploy
on:
  push:
    branches: [main]

env:
  REGISTRY: registry.registry.svc.cluster.local:5000
  IMAGE_NAME: myapp

jobs:
  build:
    runs-on: lab-runners
    outputs:
      digest: ${{ steps.push.outputs.digest }}
    steps:
      - uses: actions/checkout@v4
      # The runners' DinD layer store is an emptyDir that dies with the pod, so
      # a plain `docker build` is fully cold every run. BuildKit's registry
      # cache persists layers in zot instead (ADR-057 recipe): dependency
      # layers become LAN-local cache hits across runs.
      - name: Build and push via BuildKit registry cache (capture digest)
        id: push
        run: |
          set -euo pipefail
          # The buildx builder's buildkitd does its own registry I/O and
          # ignores dockerd's --registry-mirror/--insecure-registry — mirror
          # docker.io through zot and mark zot plain-HTTP here.
          cat > /tmp/buildkitd.toml <<'BKEOF'
          [registry."docker.io"]
            mirrors = ["registry.registry.svc.cluster.local:5000"]
          [registry."registry.registry.svc.cluster.local:5000"]
            http = true
          BKEOF
          # Pin the builder image to the current moby/buildkit release.
          docker buildx create --name ci \
            --driver docker-container \
            --driver-opt image=moby/buildkit:v0.31.2 \
            --config /tmp/buildkitd.toml
          # provenance/sbom off so the push stays a single image manifest —
          # the gate signs this exact digest and Kyverno verifies it.
          docker buildx build --builder ci \
            --cache-from "type=registry,ref=$REGISTRY/$IMAGE_NAME:buildcache" \
            --cache-to "type=registry,ref=$REGISTRY/$IMAGE_NAME:buildcache,mode=max,oci-mediatypes=true,image-manifest=true" \
            --output "type=registry,name=$REGISTRY/$IMAGE_NAME:${GITHUB_SHA}" \
            --provenance=false --sbom=false \
            --metadata-file /tmp/build-metadata.json \
            .
          digest=$(node -pe "require('/tmp/build-metadata.json')['containerimage.digest']")
          case "$digest" in
            sha256:*) : ;;
            *) echo "::error::empty/invalid image digest from buildx metadata: '${digest}'"; exit 1 ;;
          esac
          echo "digest=${digest}" >> "$GITHUB_OUTPUT"

  gate:
    needs: build
    uses: grizzly-endeavors/grizzly-platform/.github/workflows/gate.yaml@master
    with:
      image: registry.registry.svc.cluster.local:5000/myapp@${{ needs.build.outputs.digest }}
      gate_version: latest # pin to a released gate tag (e.g. v0.2.0) for reproducibility

  deploy:
    needs: gate # only runs if the gate passed and signed the image
    runs-on: lab-runners
    steps:
      - uses: actions/checkout@v4
      # ADR-020 model: bump deploy/values.yaml image tag to the signed digest
      # and commit [skip ci]; Flux reconciles. (Replace with your deploy step.)
      - name: Bump deployed tag
        run: |
          echo "Update deploy/values.yaml image to @${{ needs.build.outputs.digest }} and commit [skip ci]"
