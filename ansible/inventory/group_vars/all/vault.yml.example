---
# This is an EXAMPLE vault file
# DO NOT commit the actual vault.yml with real secrets
#
# To create your encrypted vault.yml:
# 1. Copy this file: cp vault.yml.example vault.yml
# 2. Edit vault.yml and add your real Cloudflare API token
# 3. Encrypt it: ansible-vault encrypt vault.yml
# 4. The encrypted vault.yml CAN be committed to git safely

# Cloudflare API token for DNS-01 ACME challenge
# Get this from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:DNS:Edit for the specific zone
vault_cloudflare_api_token: "your-cloudflare-api-token-here"

# iDRAC root password for R730xd remote management
# Used by r730xd-storage.yml to resolve drive bays at runtime
vault_idrac_password: "your-idrac-password-here"

# Foundation data stores (R730xd)
vault_postgres_password: "your-postgres-superuser-password-here"
vault_kv_cache_password: "your-kv-cache-password-here"
vault_minio_root_user: "your-minio-root-user-here"
vault_minio_root_password: "your-minio-root-password-here"

# Observability stack (R730xd)
vault_grafana_admin_password: "your-grafana-admin-password-here"
vault_minio_observability_access_key: "your-minio-observability-access-key-here"
vault_minio_observability_secret_key: "your-minio-observability-secret-key-here"

# OpenBao bootstrap — Infisical universal-auth machine identity credentials.
# These are the ONLY secrets the IaC layer needs once OpenBao is live; they
# grant read access to the Infisical project that holds the OpenBao unseal
# keys + root token. See docs/decisions/023-self-hosted-openbao-on-r730xd.md
# and docs/runbooks/openbao-disaster-recovery.md for rotation + recovery.
vault_infisical_openbao_client_id: "your-infisical-universal-auth-client-id"
vault_infisical_openbao_client_secret: "your-infisical-universal-auth-client-secret"
