# Caddyfile - Kubernetes Reverse Proxy Configuration
# Managed by Ansible - ansible/roles/caddy
#
# TEMPLATE SELECTION GUIDE:
# -------------------------
# Use this template (Caddyfile-k8s.j2) for:
#   - Proxying traffic to a Kubernetes cluster via NetBird VPN
#   - proxy-vps deployments routing to home cluster
#   - Wildcard *.domain routes all unmatched subdomains to K8s ingress
#
# Use Caddyfile.j2 instead when:
#   - Simple static file serving without Kubernetes
#   - No reverse proxy requirements
#   - Standalone web hosting (simple static sites, standalone containers)
#
# Required variables:
#   - caddy_root_domain: Base domain (e.g., bearflinn.com)
#   - caddy_k8s_ingress_endpoint: K8s ingress host:port
#   - caddy_services: List of non-K8s services (static, proxy, redirect)
#   - caddy_k8s_domains: List of external domains routed to K8s ingress (optional)

# Global options
{
    # Email for Let's Encrypt notifications
    email {{ caddy_email }}

{% if caddy_dns_provider | default('') == 'cloudflare' %}
    # DNS-01 ACME challenge via Cloudflare
    acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
{% endif %}

    # Admin endpoint (local only)
    admin localhost:2019

    # Prometheus metrics on admin endpoint
    servers {
        metrics
    }

    # Log settings
    log {
        output file {{ caddy_log_dir }}/caddy.log
        format json
        level INFO
    }
}

{% if caddy_metrics_port | default(false) %}
# =============================================================================
# PROMETHEUS METRICS ENDPOINT
# =============================================================================

:{{ caddy_metrics_port }} {
    metrics /metrics
    respond /healthz 200
}

{% endif %}
# =============================================================================
# STATIC/PROXY SERVICES
# =============================================================================

{% for service in caddy_services | default([]) %}
{% if service.type | default('proxy') == 'redirect' %}
# {{ service.comment | default(service.domain) }}
{{ service.domain }} {
    redir https://{{ service.target }}{uri} permanent

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }
}

{% elif service.type | default('proxy') == 'static' %}
# {{ service.comment | default(service.domain) }}
{{ service.domain }} {
    root * {{ service.root | default('/var/www/html') }}
    file_server
    encode gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }
}

{% elif service.type == 'posthog_proxy' %}
# {{ service.comment | default(service.domain) }}
{{ service.domain }} {
    handle /static/* {
        reverse_proxy https://{{ service.assets_host | default('us-assets.i.posthog.com') }} {
            header_up Host {{ service.assets_host | default('us-assets.i.posthog.com') }}
        }
    }

    handle {
        reverse_proxy https://{{ service.ingest_host | default('us.i.posthog.com') }} {
            header_up Host {{ service.ingest_host | default('us.i.posthog.com') }}
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }
}

{% else %}
# {{ service.comment | default(service.domain) }}
{{ service.domain }} {
    reverse_proxy {{ service.backend }}

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }
}

{% endif %}
{% endfor %}
# =============================================================================
# EXTERNAL DOMAINS → K8S PROXY
# =============================================================================

{% for domain_entry in caddy_k8s_domains | default([]) %}
# {{ domain_entry.comment | default(domain_entry.domain) }}
{{ domain_entry.domain }} {
    reverse_proxy http://{{ caddy_k8s_ingress_endpoint }} {
        header_up Host {host}
        header_up X-Real-IP {remote}
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/k8s-access.log
        format json
    }
}

{% endfor %}
# =============================================================================
# ROOT DOMAIN REDIRECT
# =============================================================================

{% if caddy_root_domain is defined and caddy_root_redirect_target is defined %}
# Redirect root domain to {{ caddy_root_redirect_target }}
{{ caddy_root_domain }} {
    redir https://{{ caddy_root_redirect_target }}{uri} permanent

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }
}

{% endif %}
# =============================================================================
# WILDCARD K8S PROXY - All other subdomains routed to K8s Ingress
# Endpoint: {{ caddy_k8s_ingress_endpoint }}
# One vhost (+ its own DNS-01 wildcard cert) per entry in
# caddy_wildcard_domains; falls back to [caddy_root_domain] when unset.
# =============================================================================

{% set wildcard_roots = caddy_wildcard_domains if (caddy_wildcard_domains | default([]) | length > 0) else [caddy_root_domain | default('example.com')] %}
{% for wildcard_root in wildcard_roots %}
*.{{ wildcard_root }} {
    reverse_proxy http://{{ caddy_k8s_ingress_endpoint }} {
        header_up Host {host}
        header_up X-Real-IP {remote}
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/k8s-access.log
        format json
    }
}

{% endfor %}
