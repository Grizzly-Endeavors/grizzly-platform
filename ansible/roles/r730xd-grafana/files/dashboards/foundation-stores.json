{
  "annotations": { "list": [] },
  "description": "PostgreSQL, kv-cache (Valkey), and MinIO health metrics from foundation stores",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "PostgreSQL",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "title": "Active Connections",
      "type": "stat",
      "targets": [{ "expr": "pg_stat_activity_count{datname!=\"\"}", "legendFormat": "{{ datname }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "percentage", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 80 }
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "title": "Connection Utilization",
      "type": "gauge",
      "targets": [{ "expr": "sum(pg_stat_activity_count) / pg_settings_max_connections", "legendFormat": "used" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 20 } } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "title": "Transaction Duration",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(pg_stat_activity_max_tx_duration{datname!=\"\"}[5m])", "legendFormat": "{{ datname }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 20 } } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 7 },
      "id": 4,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "title": "Transactions / sec",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(pg_stat_database_xact_commit{datname!=\"\"}[5m])", "legendFormat": "{{ datname }} commit" },
        { "expr": "rate(pg_stat_database_xact_rollback{datname!=\"\"}[5m])", "legendFormat": "{{ datname }} rollback" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 7 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Database Size",
      "type": "stat",
      "targets": [{ "expr": "pg_database_size_bytes{datname!=\"template0\",datname!=\"template1\"}", "legendFormat": "{{ datname }}" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "KV cache (Valkey)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "green", "value": 0.8 }
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 14 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "title": "Cache Hit Rate",
      "type": "gauge",
      "targets": [{ "expr": "kv_cache_keyspace_hits_total / (kv_cache_keyspace_hits_total + kv_cache_keyspace_misses_total)", "legendFormat": "hit rate" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1717986918 },
            { "color": "red", "value": 1932735283 }
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 14 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "title": "Memory Used",
      "type": "stat",
      "targets": [{ "expr": "kv_cache_memory_used_bytes", "legendFormat": "used" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 14 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "title": "Connected Clients",
      "type": "stat",
      "targets": [{ "expr": "kv_cache_connected_clients", "legendFormat": "clients" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 20 } } },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 14 },
      "id": 13,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Commands / sec",
      "type": "timeseries",
      "targets": [{ "expr": "rate(kv_cache_commands_processed_total[5m])", "legendFormat": "cmd/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 20 } } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "id": 14,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Evicted Keys",
      "type": "timeseries",
      "targets": [{ "expr": "rate(kv_cache_evicted_keys_total[5m])", "legendFormat": "evictions/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "id": 15,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Keyspace Size",
      "type": "stat",
      "targets": [{ "expr": "sum(kv_cache_db_keys)", "legendFormat": "keys" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "title": "MinIO",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 20, "gradientMode": "scheme" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "title": "S3 Request Latency",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(minio_s3_requests_ttfb_seconds_distribution_sum[5m]) / rate(minio_s3_requests_ttfb_seconds_distribution_count[5m])", "legendFormat": "avg ttfb" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 20 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom" } },
      "title": "S3 Requests / sec",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(minio_s3_requests_total[5m])", "legendFormat": "{{ api }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 20 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 22,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "S3 Errors / sec",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(minio_s3_requests_errors_total[5m])", "legendFormat": "{{ api }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 23,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Bucket Sizes",
      "type": "stat",
      "targets": [
        { "expr": "minio_bucket_usage_total_bytes", "legendFormat": "{{ bucket }}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["grizzly-platform", "foundation", "postgres", "kv-cache", "minio"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Foundation Stores",
  "uid": "foundation-stores",
  "version": 1
}
