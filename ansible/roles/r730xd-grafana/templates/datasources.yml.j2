# Managed by Ansible — r730xd-grafana role
# Grafana data source provisioning

apiVersion: 1

# Ensures no single-tenant "Tempo" datasource exists alongside the
# tenant-split ones declared below. Safe to leave in place permanently —
# runs every reconcile and is a no-op once cleared.
deleteDatasources:
  - name: Tempo
    orgId: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: {{ grafana_prometheus_url }}
    isDefault: true
    uid: prometheus
    jsonData:
      httpMethod: POST
      exemplarTraceIdDestinations:
        - name: traceID
          datasourceUid: tempo

  - name: Loki
    type: loki
    access: proxy
    url: {{ grafana_loki_url }}
    uid: loki
    jsonData:
      derivedFields:
        - name: TraceID
          matcherRegex: '"traceID":"(\w+)"'
          url: "$${__value.raw}"
          datasourceUid: tempo
          urlDisplayLabel: View Trace

  - name: Tempo (grizzly-platform)
    type: tempo
    access: proxy
    url: {{ grafana_tempo_url }}
    uid: tempo
    jsonData:
      httpHeaderName1: X-Scope-OrgID
      tracesToLogsV2:
        datasourceUid: loki
        filterByTraceID: true
      tracesToMetrics:
        datasourceUid: prometheus
      nodeGraph:
        enabled: true
      lokiSearch:
        datasourceUid: loki
    secureJsonData:
      httpHeaderValue1: grizzly-platform

  - name: Tempo (residuum-feedback)
    type: tempo
    access: proxy
    url: {{ grafana_tempo_url }}
    uid: tempo-residuum-feedback
    jsonData:
      httpHeaderName1: X-Scope-OrgID
    secureJsonData:
      httpHeaderValue1: residuum-feedback
