# Managed by Ansible — r730xd-openbao-agent role
# OpenBao Agent: AppRole auto-auth → file sink token for Prometheus (issue #41).

services:
  openbao-agent:
    image: {{ openbao_agent_image }}
    container_name: observability-openbao-agent
    restart: unless-stopped
    # Host network so the agent reaches OpenBao on the LAN IP ({{ r730xd_ip }}),
    # keeping its source address inside the AppRole secret_id_bound_cidrs.
    network_mode: host
    user: "0:0"
    entrypoint: ["/bin/bao"]
    command:
      - "agent"
      - "-config=/openbao-agent/openbao-agent.hcl"
    volumes:
      - {{ openbao_agent_compose_dir }}/openbao-agent.hcl:/openbao-agent/openbao-agent.hcl:ro
      - {{ openbao_agent_role_id_file }}:/openbao-agent/role_id:ro
      - {{ openbao_agent_secret_id_file }}:/openbao-agent/secret_id:ro
      - {{ openbao_agent_sink_dir }}:/openbao-agent/sink
    deploy:
      resources:
        limits:
          memory: {{ openbao_agent_memory_limit }}
    logging:
      driver: journald
      options:
        tag: observability-openbao-agent
