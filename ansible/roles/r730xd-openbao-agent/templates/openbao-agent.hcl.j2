# Managed by Ansible — r730xd-openbao-agent role
# Auto-auth via AppRole; write the resulting token to a file sink that
# Prometheus reads (authorization.credentials_file) to scrape sys/metrics.

pid_file = "/openbao-agent/pidfile"

vault {
  address = "{{ openbao_agent_addr }}"
  # Self-signed platform CA; the agent reaches OpenBao on the LAN IP. The
  # container has no host CA bundle, and the target is the same host.
  tls_skip_verify = true
}

auto_auth {
  method "approle" {
    mount_path = "auth/approle"
    config = {
      role_id_file_path   = "/openbao-agent/role_id"
      secret_id_file_path = "/openbao-agent/secret_id"
      # Long-lived secret_id (TTL=0, unlimited uses) — do not delete after read.
      remove_secret_id_file_after_reading = false
    }
  }

  sink "file" {
    config = {
      path = "/openbao-agent/sink/token"
      # World-readable so the Prometheus container (different UID) can read it.
      # The token is short-TTL and read-only on sys/metrics; host is LAN-only.
      mode = 0644
    }
  }
}
