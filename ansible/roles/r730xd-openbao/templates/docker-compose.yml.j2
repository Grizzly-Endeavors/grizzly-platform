# Managed by Ansible — r730xd-openbao role
# OpenBao with integrated Raft storage.
#
# Lifecycle is owned by {{ openbao_server_unit_name }} (systemd), which
# invokes `docker compose up -d` on boot so auto-unseal can sequence
# against it. Do not `docker compose down` directly; use
#   systemctl stop {{ openbao_server_unit_name }}
# to avoid leaving the unseal unit in a confused state.

services:
  openbao:
    image: {{ openbao_image }}
    container_name: foundation-openbao
    restart: unless-stopped
    network_mode: host
    # Run as root inside the container so the default entrypoint does
    # NOT try to chown /openbao/config (which fails against our ro-mount
    # of root-owned config files). Container isolation is the security
    # boundary here, not the in-container UID — no multi-tenancy, and
    # the capability set is still tight (only IPC_LOCK added).
    user: "0:0"
    # Skip the image's docker-entrypoint wrapper entirely — invoke bao
    # directly. Avoids the chown-on-startup path.
    entrypoint: ["/bin/bao"]
    # OpenBao 2.5 dropped mlock; IPC_LOCK is no longer required. Swap
    # hardening on the host replaces the in-process protection — see
    # https://openbao.org/docs/install/#post-installation-hardening
    volumes:
      - {{ openbao_config_dir }}:/openbao/config:ro
      - {{ openbao_data_dir }}:/openbao/data
      - {{ openbao_audit_dir }}:/openbao/audit
    command:
      - "server"
      - "-config=/openbao/config/openbao.hcl"
    # Healthcheck semantics: /v1/sys/health returns
    #   200 — unsealed + active
    #   429 — unsealed + standby (fine in single-node)
    #   472 — data recovery replication secondary (n/a here)
    #   473 — performance standby (n/a here)
    #   501 — not initialized
    #   503 — sealed
    # We accept 200/429/501/503 so the container is "healthy" even while
    # sealed or pre-init — the openbao-auto-unseal systemd unit handles
    # the transition from 503 → 200.
    healthcheck:
      test:
        - "CMD-SHELL"
        - >-
          wget -qO- --no-check-certificate
          --server-response
          https://127.0.0.1:{{ openbao_api_port }}/v1/sys/health?standbyok=true&sealedcode=200&uninitcode=200
          2>&1 | grep -qE 'HTTP/1\.[01] (200|429)'
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 10s
    ulimits:
      # Go runtime creates OS threads on demand; the default Docker nproc
      # limit is low enough to cause fatal crashes under normal load.
      nproc:
        soft: 65535
        hard: 65535
    logging:
      driver: journald
      options:
        tag: foundation-openbao
