#!/usr/bin/env bash
# Managed by Ansible — r730xd-openbao role
# Scripted unseal: fetch unseal shares from Infisical and submit them to
# OpenBao. Runs as a systemd oneshot at every boot after the container
# is up and the API is reachable.
#
# Key material never touches disk: Infisical CLI output is piped in-memory
# to `bao operator unseal` via a process substitution. Logs only the
# seal-state transition, never the keys themselves.
#
# Exit 0: vault is unsealed at end of run (including no-op if already unsealed).
# Exit 1: anything else — Infisical auth, missing keys, seal still sealed, etc.

set -euo pipefail

ADDR="{{ openbao_loopback_addr }}"
CA_CERT="{{ openbao_tls_dir }}/ca.crt"
AUTH_FILE="{{ openbao_infisical_auth_env_file }}"
THRESHOLD={{ openbao_unseal_threshold }}
PREFIX="{{ openbao_infisical_unseal_key_prefix }}"

export VAULT_ADDR="${ADDR}"
export BAO_ADDR="${ADDR}"
export VAULT_CACERT="${CA_CERT}"
export BAO_CACERT="${CA_CERT}"

log() { echo "[openbao-auto-unseal] $*"; }
die() { log "ERROR: $*"; exit 1; }

# Snapshot status once. `bao status` exits 2 when sealed or uninitialized,
# which — combined with `set -o pipefail` — would make any direct pipe
# into grep return non-zero and break our checks. Capture the output
# separately with `|| true` to decouple the inspection from the exit code.
STATUS_JSON="$(bao status -format=json 2>/dev/null || true)"

# Early-out: already unsealed (idempotent; systemd may restart this unit).
if printf '%s' "${STATUS_JSON}" | grep -q '"sealed": *false'; then
    log "vault already unsealed — nothing to do"
    exit 0
fi

# Also early-out if the vault has never been initialized — the bootstrap
# playbook hasn't run yet. Don't treat this as a failure; the human
# operator will run bootstrap-openbao.yml on first deploy.
if printf '%s' "${STATUS_JSON}" | grep -q '"initialized": *false'; then
    log "vault is not yet initialized — skipping unseal (run bootstrap-openbao.yml)"
    exit 0
fi

[ -r "${AUTH_FILE}" ] || die "auth file ${AUTH_FILE} not readable"
# shellcheck disable=SC1090
source "${AUTH_FILE}"

: "${INFISICAL_CLIENT_ID:?unset in ${AUTH_FILE}}"
: "${INFISICAL_CLIENT_SECRET:?unset in ${AUTH_FILE}}"
: "${INFISICAL_PROJECT_ID:?unset in ${AUTH_FILE}}"
: "${INFISICAL_ENV:?unset in ${AUTH_FILE}}"

# Bounded retry. The unit is still a oneshot with Restart=no (fail loudly so
# Prometheus alerts), but a *transient* boot-time DNS/network race reaching
# Infisical shouldn't leave the vault sealed until a human notices. Retry a few
# times with a short delay; if Infisical is genuinely unreachable we still exit
# 1 after the budget and the alert fires. Keep RETRY_MAX*RETRY_DELAY (+ per-try
# network timeouts) under the unit's TimeoutStartSec.
RETRY_MAX={{ openbao_unseal_retry_max | default(5) }}
RETRY_DELAY={{ openbao_unseal_retry_delay | default(15) }}

# One full unseal attempt. Returns 0 once unsealed, non-zero on any failure
# (Infisical auth, key fetch, submit, or still-sealed). Called from a retry
# loop, so it must `return` — never `exit` — on failure. `set -e` is suspended
# inside a function invoked in an `if`/`||` context, so failures are handled
# explicitly here rather than aborting the script.
attempt_unseal() {
    local token key i key_name
    log "authenticating to Infisical (project ${INFISICAL_PROJECT_ID}, env ${INFISICAL_ENV})"
    token="$(infisical login \
        --method=universal-auth \
        --client-id="${INFISICAL_CLIENT_ID}" \
        --client-secret="${INFISICAL_CLIENT_SECRET}" \
        --plain --silent)" || { log "Infisical login failed"; return 1; }
    [ -n "${token}" ] || { log "Infisical login returned empty token"; return 1; }

    # Submit shares 1..N until the threshold is met; stop early if the vault
    # transitions to unsealed mid-way. Each unseal is a separate HTTP request.
    for i in $(seq 1 "${THRESHOLD}"); do
        key_name="${PREFIX}${i}"
        log "submitting unseal share ${i}/${THRESHOLD}"
        key="$(infisical secrets get "${key_name}" \
            --projectId="${INFISICAL_PROJECT_ID}" \
            --env="${INFISICAL_ENV}" \
            --token="${token}" \
            --plain --silent)" || { log "fetch of ${key_name} failed"; return 1; }
        [ -n "${key}" ] || { log "Infisical returned empty value for ${key_name}"; return 1; }
        bao operator unseal -format=json "${key}" >/dev/null || { unset key; log "unseal submit failed"; return 1; }
        unset key

        if bao status -format=json 2>/dev/null | grep -q '"sealed": false'; then
            log "vault unsealed after ${i} share(s)"
            return 0
        fi
    done

    log "submitted ${THRESHOLD} shares but vault is still sealed"
    return 1
}

attempt=1
while [ "${attempt}" -le "${RETRY_MAX}" ]; do
    if attempt_unseal; then
        exit 0
    fi
    if [ "${attempt}" -lt "${RETRY_MAX}" ]; then
        log "attempt ${attempt}/${RETRY_MAX} failed — retrying in ${RETRY_DELAY}s (transient DNS/network at boot?)"
        sleep "${RETRY_DELAY}"
    fi
    attempt=$((attempt + 1))
done

die "unseal failed after ${RETRY_MAX} attempts — check Infisical reachability and bao status"
