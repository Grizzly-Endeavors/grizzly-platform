# Managed by Ansible — r730xd-prometheus role
# Alertmanager configuration

route:
  group_by: ['alertname', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: 'default'
  routes:
    # Watchdog alert — silence it (used for dead-man's-switch only)
    - match:
        alertname: PrometheusWatchdog
      receiver: 'null'

receivers:
  - name: 'null'

{% if monitoring_discord_webhook_url is defined and monitoring_discord_webhook_url %}
  - name: 'default'
    discord_configs:
      - webhook_url: '{{ monitoring_discord_webhook_url }}'
        send_resolved: true
        title: '{% raw %}{{ if eq .Status "firing" }}🔥{{ else }}✅{{ end }} [{{ .Status | toUpper }}] {{ .GroupLabels.SortedPairs.Values | join " " }}{% endraw %}'
        message: '{% raw %}{{ range .Alerts }}• {{ if .Annotations.summary }}{{ .Annotations.summary }}{{ else if .Annotations.description }}{{ .Annotations.description }}{{ else }}{{ .Labels.alertname }} on {{ .Labels.instance }}{{ end }}{{ "\n" }}{{ end }}{% endraw %}'
{% elif monitoring_alert_webhook_url is defined and monitoring_alert_webhook_url %}
  - name: 'default'
    webhook_configs:
      - url: '{{ monitoring_alert_webhook_url }}'
        send_resolved: true
{% else %}
  # No alert destination configured — alerts visible in Alertmanager UI only.
  # Set monitoring_discord_webhook_url in group_vars to enable dispatch.
  - name: 'default'
{% endif %}
