# Managed by Ansible — r730xd-prometheus role
# Prometheus scrape configuration for the grizzly-platform observability stack

global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}

rule_files:
  - "rules/*.yml"

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            # Compose service name — Prometheus and Alertmanager run as
            # separate containers on the bridge network, so "localhost" inside
            # this container is NOT Alertmanager. The internal listen port is
            # always 9093 regardless of the published host port.
            - "alertmanager:9093"

scrape_configs:
  - job_name: "node"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/nodes.yml"
          - "/etc/prometheus/targets.d/node-*.yml"
        refresh_interval: 30s

  - job_name: "ipmi"
    scrape_interval: 30s
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/ipmi.yml"
          - "/etc/prometheus/targets.d/ipmi-*.yml"
        refresh_interval: 30s

{% for svc in prometheus_observability_targets %}
  - job_name: "{{ svc.job }}"
{% if svc.metrics_path is defined %}
    metrics_path: "{{ svc.metrics_path }}"
{% endif %}
    static_configs:
      - targets:
          - "{{ svc.target }}"
        labels:
          env: "grizzly-platform"

{% endfor %}
  - job_name: "etcd"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-etcd.yml"
        refresh_interval: 30s

  # OpenBao health probe. Scrapes /v1/sys/health without a token; the
  # endpoint returns 200 when up+unsealed and 503 when sealed, so
  # `up{job="openbao"} == 0` fires for "down OR sealed". The operator
  # distinguishes via `systemctl status foundation-openbao
  # openbao-auto-unseal`. A follow-up (wiring in the prometheus-readonly
  # token) will add internal metrics like vault_core_unsealed.
  - job_name: "openbao"
    scheme: https
    metrics_path: /v1/sys/health
    params:
      standbyok: ["true"]
      perfstandbyok: ["true"]
    tls_config:
      # Self-signed CA from the r730xd-openbao role. The Prometheus
      # container doesn't have the host CA bundle; skipping verify is
      # acceptable because the target is the same host (r730xd→r730xd).
      insecure_skip_verify: true
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/openbao.yml"
        refresh_interval: 30s

{% if prometheus_k8s_apiserver_target is defined and prometheus_k8s_apiserver_target %}
  - job_name: "kube-apiserver"
    scheme: https
    tls_config:
      ca_file: /etc/prometheus/k8s-auth/ca.crt
      insecure_skip_verify: false
    authorization:
      credentials_file: /etc/prometheus/k8s-auth/token
    static_configs:
      - targets:
          - "{{ prometheus_k8s_apiserver_target }}"
        labels:
          env: "grizzly-platform"
          component: "kube-apiserver"
{% endif %}

  - job_name: "kubelet"
    scheme: https
    tls_config:
      ca_file: /etc/prometheus/k8s-auth/ca.crt
      # kubelet self-signed certs use hostnames, not IPs — skip server cert verification
      # Authentication is still enforced via bearer token + webhook authz
      insecure_skip_verify: true
    authorization:
      credentials_file: /etc/prometheus/k8s-auth/token
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-kubelet.yml"
        refresh_interval: 30s

  - job_name: "cilium-agent"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-cilium-agent.yml"
        refresh_interval: 30s

  # Cilium operator is a single-replica, hostNetwork Deployment that floats
  # across nodes, so a static file_sd target can't track it. Discover the pod
  # via the kube API and scrape it on its node IP:9963. Uses the
  # prometheus-metrics SA token (needs pods list/watch — granted in
  # setup-k8s-cluster-metrics.yml).
  - job_name: "cilium-operator"
    kubernetes_sd_configs:
      - role: pod
        api_server: "https://{{ hostvars[groups['k8s_control_plane'][0]]['ansible_host'] }}:6443"
        tls_config:
          ca_file: /etc/prometheus/k8s-auth/ca.crt
        authorization:
          credentials_file: /etc/prometheus/k8s-auth/token
        namespaces:
          names:
            - kube-system
    relabel_configs:
      - source_labels: [__meta_kubernetes_pod_label_io_cilium_app]
        regex: operator
        action: keep
      - source_labels: [__meta_kubernetes_pod_ip]
        regex: (.+)
        target_label: __address__
        replacement: "${1}:9963"
      - source_labels: [__meta_kubernetes_pod_node_name]
        target_label: instance
      - target_label: env
        replacement: "grizzly-platform"
      - target_label: component
        replacement: "cilium-operator"

  - job_name: "hubble"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-hubble.yml"
        refresh_interval: 30s

  - job_name: "kube-state-metrics"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-kube-state-metrics.yml"
        refresh_interval: 30s

  - job_name: "flux-system"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-flux.yml"
        refresh_interval: 30s

  - job_name: "arc-controller"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-arc.yml"
        refresh_interval: 30s

  - job_name: "argo-workflows"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-argo.yml"
        refresh_interval: 30s

  # zot OCI registry metrics (Prometheus extension on the registry HTTP port,
  # reached via the registry NodePort; default /metrics path).
  - job_name: "registry-zot"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-zot.yml"
        refresh_interval: 30s

  # Kyverno admission controller — the CI gate's deploy boundary. With
  # failurePolicy:Fail, Kyverno being down blocks pod admission in gated
  # namespaces, so this scrape feeds the KyvernoDown alert.
  - job_name: "kyverno"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-kyverno.yml"
        refresh_interval: 30s

  - job_name: "ingress-nginx"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-ingress-nginx.yml"
        refresh_interval: 30s

  - job_name: "cert-manager"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-cert-manager.yml"
        refresh_interval: 30s

{% if prometheus_blackbox_targets is defined and prometheus_blackbox_targets | length > 0 %}
  - job_name: "blackbox"
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
{% for target in prometheus_blackbox_targets %}
          - "{{ target }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: env
        replacement: "grizzly-platform"
      - target_label: __address__
        replacement: "{{ prometheus_blackbox_exporter }}"
{% endif %}
