# Managed by Ansible — r730xd-prometheus role
# Alert rules for the grizzly-platform self-hosted infrastructure
# Source: docs/monitoring-integration.md

groups:
  - name: storage
    rules:
      - alert: DiskSpaceWarning
        expr: (1 - node_filesystem_avail_bytes / node_filesystem_size_bytes) * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            Disk {{ '{{' }} $labels.mountpoint {{ '}}' }} is
            {{ '{{' }} $value | printf "%.0f" {{ '}}' }}% full
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: DiskSpaceCritical
        expr: (1 - node_filesystem_avail_bytes / node_filesystem_size_bytes) * 100 > 95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            Disk {{ '{{' }} $labels.mountpoint {{ '}}' }} is
            {{ '{{' }} $value | printf "%.0f" {{ '}}' }}% full
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: SmartUnhealthy
        expr: monitoring_smart_healthy == 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: >-
            SMART health check failed for {{ '{{' }} $labels.device {{ '}}' }}
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: DriveTemperatureHigh
        expr: monitoring_smart_temperature_celsius > 55
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: >-
            Drive {{ '{{' }} $labels.device {{ '}}' }} at
            {{ '{{' }} $value {{ '}}' }}°C
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ReallocatedSectors
        expr: monitoring_smart_reallocated_sectors > 5
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: >-
            {{ '{{' }} $value {{ '}}' }} reallocated sectors on
            {{ '{{' }} $labels.device {{ '}}' }}
            ({{ '{{' }} $labels.instance {{ '}}' }})

  - name: hardware
    rules:
      - alert: PSUFailure
        expr: monitoring_ipmi_psu_failed > 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: "Power supply failure detected on {{ '{{' }} $labels.instance {{ '}}' }}"

      - alert: CPUTemperatureHigh
        expr: monitoring_ipmi_temperature_celsius > 85
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: >-
            CPU at {{ '{{' }} $value {{ '}}' }}°C
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ECCMemoryErrors
        expr: monitoring_ipmi_memory_errors_sel > 0
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: "ECC memory errors detected on {{ '{{' }} $labels.instance {{ '}}' }}"

  - name: services
    rules:
      - alert: ServiceDown
        expr: monitoring_service_up == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            Service {{ '{{' }} $labels.service {{ '}}' }} is down
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: SystemdFailedUnits
        expr: monitoring_systemd_failed_units > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            {{ '{{' }} $value {{ '}}' }} failed systemd unit(s)
            on {{ '{{' }} $labels.instance {{ '}}' }}

  - name: nfs
    rules:
      - alert: NFSDown
        expr: monitoring_nfs_service_up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "NFS server is down on {{ '{{' }} $labels.instance {{ '}}' }} — K8s PVCs affected"

      - alert: NFSRPCErrors
        expr: rate(node_nfsd_rpc_errors_total[5m]) > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            NFS RPC errors on {{ '{{' }} $labels.instance {{ '}}' }}
            ({{ '{{' }} $value | printf "%.2f" {{ '}}' }}/s)

  - name: snapraid
    rules:
      - alert: SnapRAIDErrors
        expr: monitoring_snapraid_errors > 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: "SnapRAID sync errors on {{ '{{' }} $labels.instance {{ '}}' }}"

      - alert: SnapRAIDScrubOverdue
        expr: monitoring_snapraid_last_scrub_days > 7
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: >-
            SnapRAID scrub is {{ '{{' }} $value {{ '}}' }} days overdue
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: SnapRAIDSyncFailed
        expr: monitoring_snapraid_sync_failed > 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: >-
            SnapRAID sync service failing on {{ '{{' }} $labels.instance {{ '}}' }}
            — parity is going stale, new data is unprotected

  - name: zfs
    rules:
      - alert: ZFSPoolDegraded
        expr: monitoring_zfs_pool_healthy == 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: >-
            ZFS pool {{ '{{' }} $labels.pool {{ '}}' }} is unhealthy
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ZFSPoolCapacityWarning
        expr: monitoring_zfs_pool_capacity_percent > 80
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            ZFS pool {{ '{{' }} $labels.pool {{ '}}' }} is
            {{ '{{' }} $value {{ '}}' }}% full
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ZFSPoolCapacityCritical
        expr: monitoring_zfs_pool_capacity_percent > 90
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            ZFS pool {{ '{{' }} $labels.pool {{ '}}' }} is
            {{ '{{' }} $value {{ '}}' }}% full
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ZFSPoolErrors
        expr: monitoring_zfs_pool_errors > 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: >-
            ZFS pool {{ '{{' }} $labels.pool {{ '}}' }} has
            {{ '{{' }} $value {{ '}}' }} I/O errors
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ZFSScrubOverdue
        expr: monitoring_zfs_scrub_age_days > 8
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: >-
            ZFS pool {{ '{{' }} $labels.pool {{ '}}' }} scrub is
            {{ '{{' }} $value {{ '}}' }} days overdue
            on {{ '{{' }} $labels.instance {{ '}}' }}

  - name: iscsi
    rules:
      - alert: ISCSITargetDown
        expr: monitoring_iscsi_target_service_up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: >-
            iSCSI target service is down
            on {{ '{{' }} $labels.instance {{ '}}' }} — K8s block storage PVCs affected

      - alert: ISCSITargetUnresponsive
        expr: monitoring_iscsi_target_lio_responsive == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            iSCSI LIO target subsystem is not responding
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ISCSINoTargets
        expr: monitoring_iscsi_target_count == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            No iSCSI targets configured
            on {{ '{{' }} $labels.instance {{ '}}' }} — democratic-csi may not be functioning

  - name: kubernetes
    rules:
      - alert: KubeAPIServerDown
        expr: up{job="kube-apiserver"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Kubernetes API server is unreachable"

      - alert: EtcdDown
        expr: up{job="etcd"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "etcd is unreachable on {{ '{{' }} $labels.instance {{ '}}' }}"

      - alert: EtcdDbSizeLarge
        expr: etcd_mvcc_db_total_size_in_bytes > 4294967296
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            etcd database is {{ '{{' }} $value | humanize1024 {{ '}}' }}B
            (threshold 4GB)

      - alert: NodeNotReady
        expr: kube_node_status_condition{condition="Ready",status="true"} == 0
        for: 3m
        labels:
          severity: critical
        annotations:
          summary: >-
            K8s node {{ '{{' }} $labels.node {{ '}}' }} is NotReady

      - alert: KubeletDown
        expr: up{job="kubelet"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            Kubelet is unreachable on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: CiliumAgentDown
        expr: up{job="cilium-agent"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            Cilium agent is down on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: PVCPendingTooLong
        expr: kube_persistentvolumeclaim_status_phase{phase="Pending"} == 1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            PVC {{ '{{' }} $labels.namespace {{ '}}' }}/{{ '{{' }} $labels.persistentvolumeclaim {{ '}}' }}
            has been Pending for more than 5 minutes — check CSI driver logs

      - alert: DemocraticCSIPodNotReady
        expr: kube_pod_status_ready{namespace="democratic-csi", condition="true"} == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            democratic-csi pod {{ '{{' }} $labels.pod {{ '}}' }}
            is not ready for more than 5 minutes

      - alert: DemocraticCSIPodCrashLooping
        expr: increase(kube_pod_container_status_restarts_total{namespace="democratic-csi"}[15m]) > 3
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: >-
            democratic-csi pod {{ '{{' }} $labels.pod {{ '}}' }}
            has restarted {{ '{{' }} $value | printf "%.0f" {{ '}}' }} times in 15 minutes

      - alert: FluxReconciliationFailure
        expr: gotk_reconcile_condition{type="Ready",status="False"} == 1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            Flux {{ '{{' }} $labels.kind {{ '}}' }}
            {{ '{{' }} $labels.namespace {{ '}}' }}/{{ '{{' }} $labels.name {{ '}}' }}
            reconciliation failed

      - alert: FluxSuspended
        expr: gotk_suspend_status == 1
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: >-
            Flux {{ '{{' }} $labels.kind {{ '}}' }}
            {{ '{{' }} $labels.namespace {{ '}}' }}/{{ '{{' }} $labels.name {{ '}}' }}
            is suspended

      - alert: ARCControllerDown
        expr: up{job="arc-controller"} == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "ARC controller is unreachable — GitHub Actions runners cannot scale"

      - alert: ARCRunnerPodCrashLooping
        expr: increase(kube_pod_container_status_restarts_total{namespace="arc-runners"}[15m]) > 3
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: >-
            ARC runner pod {{ '{{' }} $labels.pod {{ '}}' }}
            has restarted {{ '{{' }} $value | printf "%.0f" {{ '}}' }} times in 15 minutes

      - alert: ArgoControllerDown
        expr: up{job="argo-workflows",component="workflow-controller"} == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Argo Workflow controller is unreachable"

      - alert: ArgoServerDown
        expr: up{job="argo-workflows",component="argo-server"} == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Argo Server is unreachable — CLI/API access unavailable"

      - alert: ArgoWorkflowFailed
        expr: increase(argo_workflows_count{status="Failed"}[15m]) > 0
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: "Argo Workflow failures detected in the last 15 minutes"

      # --- Phase 6: ingress-nginx + cert-manager ---
      # Metric names verified against live Prometheus (nginx_ingress v4.11.3,
      # cert-manager v1.16.2) after initial traffic + a test Certificate.
      - alert: IngressNginxDown
        expr: up{job="ingress-nginx"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "ingress-nginx controller is unreachable — external traffic broken"

      - alert: IngressNginx5xxRate
        expr: sum(rate(nginx_ingress_controller_request_duration_seconds_count{status=~"5.."}[5m])) > 1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            ingress-nginx serving {{ '{{' }} $value | printf "%.2f" {{ '}}' }} 5xx/s
            (sustained over 5m)

      - alert: CertManagerDown
        expr: up{job="cert-manager"} == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "cert-manager controller is unreachable — new Certificates will not be issued or renewed"

      - alert: CertificateExpiringSoon
        expr: certmanager_certificate_expiration_timestamp_seconds - time() < 86400 * 14
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: >-
            Certificate {{ '{{' }} $labels.namespace {{ '}}' }}/{{ '{{' }} $labels.name {{ '}}' }}
            expires in less than 14 days

      # certmanager_certificate_ready_status is a gauge emitted per condition
      # (True / False / Unknown). A value of 1 on condition="False" means the
      # Certificate is explicitly in a failed state.
      - alert: CertificateNotReady
        expr: certmanager_certificate_ready_status{condition="False"} == 1
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: >-
            Certificate {{ '{{' }} $labels.namespace {{ '}}' }}/{{ '{{' }} $labels.name {{ '}}' }}
            is not Ready (stuck in a failed state)

  - name: observability
    rules:
      - alert: TargetDown
        expr: up == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            Scrape target {{ '{{' }} $labels.job {{ '}}' }}/{{ '{{' }} $labels.instance {{ '}}' }}
            is down

      - alert: PrometheusWatchdog
        expr: vector(1)
        labels:
          severity: none
        annotations:
          summary: "Prometheus watchdog — this alert should always be firing"

  - name: foundation-stores
    rules:
      - alert: PostgresConnectionsHigh
        expr: pg_stat_activity_count > 80
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            PostgreSQL has {{ '{{' }} $value {{ '}}' }} active connections
            (max 100)

      - alert: PostgresDown
        expr: pg_up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "PostgreSQL exporter cannot connect to database"

      - alert: RedisMemoryHigh
        expr: redis_memory_used_bytes / redis_memory_max_bytes > 0.85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            Redis memory at {{ '{{' }} $value | humanizePercentage {{ '}}' }}
            of limit

      - alert: RedisDown
        expr: redis_up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Redis exporter cannot connect to Redis"

      - alert: RedisEvictions
        expr: rate(redis_evicted_keys_total[5m]) > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Redis is evicting keys — memory pressure"

  - name: openbao
    rules:
      # `up{job="openbao"} == 0` fires for EITHER "server down" OR
      # "server sealed" — /v1/sys/health returns 503 when sealed, which
      # Prometheus counts as a scrape failure. The operator triages via
      # `systemctl status foundation-openbao openbao-auto-unseal` on
      # r730xd. See docs/runbooks/openbao-disaster-recovery.md.
      - alert: OpenbaoUnavailable
        expr: up{job="openbao"} == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: >-
            OpenBao is unavailable (down or sealed)
            on {{ '{{' }} $labels.instance {{ '}}' }}
          runbook: "docs/runbooks/openbao-disaster-recovery.md"

      # Systemd-level signal: the openbao-auto-unseal.service failed at
      # boot. This catches the case where OpenBao itself is up but
      # auto-unseal couldn't fetch keys from Infisical.
      - alert: OpenbaoAutoUnsealFailed
        expr: node_systemd_unit_state{name="openbao-auto-unseal.service",state="failed"} == 1
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: >-
            openbao-auto-unseal.service is in failed state on
            {{ '{{' }} $labels.instance {{ '}}' }} — check Infisical reachability + auth

      # Audit log volume: if the audit sink can't write, OpenBao refuses
      # every subsequent request (audit is a hard requirement once a
      # device is declared). Two thresholds — the warning gives time to
      # triage, the critical page says "fix it or OpenBao bricks."
      - alert: OpenbaoAuditLogDiskFull
        expr: |
          (node_filesystem_avail_bytes{mountpoint="/mnt/zfs"} /
           node_filesystem_size_bytes{mountpoint="/mnt/zfs"}) < 0.15
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: >-
            ZFS foundation tier <15% free on
            {{ '{{' }} $labels.instance {{ '}}' }} —
            OpenBao audit log growth may starve other foundation stores

      - alert: OpenbaoAuditLogDiskCritical
        expr: |
          (node_filesystem_avail_bytes{mountpoint="/mnt/zfs"} /
           node_filesystem_size_bytes{mountpoint="/mnt/zfs"}) < 0.05
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: >-
            ZFS foundation tier <5% free on
            {{ '{{' }} $labels.instance {{ '}}' }} —
            OpenBao will start rejecting requests when the audit sink
            can't write. Free space now or manually disable the audit
            device as a last resort: `bao audit disable main/`.

  - name: endpoints
    rules:
      - alert: EndpointDown
        expr: probe_success == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            {{ '{{' }} $labels.instance {{ '}}' }} is unreachable

      - alert: SSLCertExpiringSoon
        expr: probe_ssl_earliest_cert_expiry - time() < 86400 * 14
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: >-
            SSL certificate for {{ '{{' }} $labels.instance {{ '}}' }}
            expires in less than 14 days

  - name: containers
    rules:
      - alert: ContainerCPUHigh
        expr: rate(container_cpu_usage_seconds_total{name!=""}[5m]) > 0.9
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: >-
            Container {{ '{{' }} $labels.name {{ '}}' }} CPU usage above 90%

      - alert: ContainerMemoryHigh
        expr: container_memory_usage_bytes{name!=""} / container_spec_memory_limit_bytes{name!=""} > 0.9
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            Container {{ '{{' }} $labels.name {{ '}}' }} memory at
            {{ '{{' }} $value | humanizePercentage {{ '}}' }} of limit

      - alert: ContainerRestarting
        expr: increase(container_restart_count{name!=""}[15m]) > 3
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: >-
            Container {{ '{{' }} $labels.name {{ '}}' }} restarted
            {{ '{{' }} $value {{ '}}' }} times in 15 minutes

  # Phase 7b app-level alerts. One pair per service:
  #   - <App>IngressErrors  — 5xx ratio > 1% for 5m (ingress-nginx host label)
  #   - <App>Down           — Deployment has zero Available replicas for 2m
  # Hosts are matched against ingress-nginx's `host` label, which comes
  # from the Ingress resource (see the respective app's deploy/values.yaml).
  - name: apps
    rules:
      - alert: LandingPageIngressErrors
        expr: |
          sum(rate(nginx_ingress_controller_requests{host="landing.bearflinn.com",status=~"5.."}[5m]))
            / clamp_min(sum(rate(nginx_ingress_controller_requests{host="landing.bearflinn.com"}[5m])), 1e-9) > 0.01
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "landing.bearflinn.com 5xx rate > 1% for 5m"

      - alert: LandingPageDown
        expr: kube_deployment_status_replicas_available{namespace="landing-page",deployment="landing-page"} < 1
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "landing-page has no available replicas"

      - alert: CazPortfolioIngressErrors
        expr: |
          sum(rate(nginx_ingress_controller_requests{host=~"(www\\.)?pennydreadfulsfx\\.com",status=~"5.."}[5m]))
            / clamp_min(sum(rate(nginx_ingress_controller_requests{host=~"(www\\.)?pennydreadfulsfx\\.com"}[5m])), 1e-9) > 0.01
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "pennydreadfulsfx.com 5xx rate > 1% for 5m"

      - alert: CazPortfolioDown
        expr: kube_deployment_status_replicas_available{namespace="caz-portfolio",deployment="caz-portfolio"} < 1
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "caz-portfolio has no available replicas"

      - alert: ResumeSiteIngressErrors
        expr: |
          sum(rate(nginx_ingress_controller_requests{host="resume.bearflinn.com",status=~"5.."}[5m]))
            / clamp_min(sum(rate(nginx_ingress_controller_requests{host="resume.bearflinn.com"}[5m])), 1e-9) > 0.01
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "resume.bearflinn.com 5xx rate > 1% for 5m"

      - alert: ResumeSiteDown
        expr: kube_deployment_status_replicas_available{namespace="resume-site",deployment="resume-site"} < 1
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "resume-site has no available replicas"

  - name: ci-gate
    rules:
      - alert: ZotRegistryDown
        expr: up{job="registry-zot"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "zot OCI registry is down — image builds, the gate, and pulls all break"

      - alert: KyvernoDown
        # Kyverno is the deploy boundary with failurePolicy:Fail; if it's down,
        # pod admission in gated namespaces is blocked. Treat as critical.
        expr: up{job="kyverno"} == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Kyverno admission controller is down — deploys to gated namespaces will fail"

      - alert: GateSignatureVerificationFailing
        # verify-gate-signature rejecting/flagging images: unsigned images being
        # deployed, or the cosign public key is wrong/placeholder. In Audit this
        # is report-only; in Enforce it blocks the deploy.
        expr: |
          sum(rate(kyverno_policy_results_total{policy_name="verify-gate-signature",policy_validation_mode="enforce",rule_result="fail"}[15m])) > 0
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "CI gate signature verification is failing for one or more images"
