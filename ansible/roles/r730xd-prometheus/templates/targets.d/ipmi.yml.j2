# Managed by Ansible — r730xd-prometheus role
# Static ipmi_exporter targets (prometheus_ipmi_targets). Per-worker targets
# live in separate ipmi-*.yml files written by setup-k8s-worker.yml.
{% for target in prometheus_ipmi_targets %}
- targets:
    - "{{ target.target }}"
  labels:
    env: "grizzly-platform"
{% for key, value in target.labels.items() %}
    {{ key }}: "{{ value }}"
{% endfor %}
{% endfor %}
