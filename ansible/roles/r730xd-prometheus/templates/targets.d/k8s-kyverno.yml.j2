# Managed by Ansible — r730xd-prometheus role
# Kyverno admission controller metrics, exposed via NodePort 30888
# (kubernetes/infrastructure/kyverno/metrics-service.yaml).
- targets:
    - "{{ hostvars[groups['k8s_control_plane'][0]]['ansible_host'] }}:30888"
  labels:
    env: "grizzly-platform"
    instance: "kyverno-admission"
    component: "admission-controller"
