# Managed by Ansible — r730xd-prometheus role
# Static node_exporter targets (prometheus_node_targets). Per-worker targets
# live in separate node-*.yml files written by setup-k8s-worker.yml.
{% for target in prometheus_node_targets %}
- targets:
    - "{{ target.target }}"
  labels:
    env: "homelab"
{% for key, value in target.labels.items() %}
    {{ key }}: "{{ value }}"
{% endfor %}
{% endfor %}
