# Managed by Ansible — r730xd-residuum role
# Owns the residuum container lifecycle so it sequences after the ZFS mount.
# Container-level restart=unless-stopped handles crash recovery; this unit
# handles boot ordering and the mount guard (refuse to start onto an empty
# mountpoint if ZFS failed to mount — that would silently bootstrap a blank
# agent workspace over the real one).

[Unit]
Description=Residuum personal agent (Docker Compose)
Requires=docker.service
After=docker.service network-online.target zfs-mount.service
Wants=network-online.target
# All agent state lives on ZFS; refuse to start if the mount is missing.
RequiresMountsFor={{ residuum_data_dir }}

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory={{ residuum_compose_dir }}
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=120

[Install]
WantedBy=multi-user.target
