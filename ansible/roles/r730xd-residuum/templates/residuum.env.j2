# Managed by Ansible — r730xd-residuum role. Mode 0600, no_log. Secrets only.
# Kept in an env_file (not the compose body) so they stay off the process
# command line and out of the compose file. Referenced from config.toml /
# providers.toml as ${VAR}.

# Timezone is required for a headless boot — without it residuum fails config
# load and falls back to the interactive setup wizard.
RESIDUUM_TIMEZONE={{ residuum_timezone }}

# Model providers
OLLAMA_API_KEY={{ residuum_ollama_api_key }}
GEMINI_API_KEY={{ residuum_gemini_api_key }}

# Cloud relay bearer token (browser access via agent-residuum.com)
RESIDUUM_CLOUD_TOKEN={{ residuum_cloud_token }}

# GitHub — org-wide token used by both `gh` and git (via gh's credential
# helper) for the IaC change workflow. Changes land as PRs, and the agent can
# merge its own; Flux reconciles on merge.
GH_TOKEN={{ residuum_github_token }}
GITHUB_TOKEN={{ residuum_github_token }}

# Commit identity for agent-authored IaC changes
GIT_AUTHOR_NAME={{ residuum_git_author_name }}
GIT_AUTHOR_EMAIL={{ residuum_git_author_email }}
GIT_COMMITTER_NAME={{ residuum_git_author_name }}
GIT_COMMITTER_EMAIL={{ residuum_git_author_email }}

# Point git at the gitconfig on the STATE VOLUME. Without this git would look
# for ~/.gitconfig on the container's ephemeral overlay, find nothing, and have
# no credential helper — so pushes and private-repo access fail even though
# GH_TOKEN is set (git never reads GH_TOKEN).
GIT_CONFIG_GLOBAL={{ residuum_container_home }}/gitconfig
