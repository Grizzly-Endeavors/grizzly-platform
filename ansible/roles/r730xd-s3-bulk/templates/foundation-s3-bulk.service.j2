# Managed by Ansible — r730xd-s3-bulk role
# Owns the versitygw (bulk / MergerFS+SnapRAID) container lifecycle so it
# sequences after the MergerFS pool is mounted. Container-level
# restart=unless-stopped handles crash recovery; this unit handles boot
# ordering and the mount guard (refuse to start the gateway onto an empty
# mountpoint if MergerFS failed to mount). RequiresMountsFor resolves and
# orders after the /mnt/pool mount unit automatically.

[Unit]
Description=versitygw S3 gateway — bulk tier (Docker Compose)
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target
# Data lives on the MergerFS pool; refuse to start if the mount is missing.
RequiresMountsFor={{ s3_bulk_data_dir }}

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory={{ s3_bulk_compose_dir }}
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=120

[Install]
WantedBy=multi-user.target
