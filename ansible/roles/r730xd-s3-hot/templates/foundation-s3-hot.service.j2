# Managed by Ansible — r730xd-s3-hot role
# Owns the versitygw (hot / ZFS) container lifecycle so it sequences after the
# ZFS mount. Container-level restart=unless-stopped handles crash recovery;
# this unit handles boot ordering and the mount guard (refuse to start the
# gateway onto an empty mountpoint if ZFS failed to mount).

[Unit]
Description=versitygw S3 gateway — hot tier (Docker Compose)
Requires=docker.service
After=docker.service network-online.target zfs-mount.service
Wants=network-online.target
# Data lives on ZFS; refuse to start if the mount is missing.
RequiresMountsFor={{ s3_hot_data_dir }}

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory={{ s3_hot_compose_dir }}
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=120

[Install]
WantedBy=multi-user.target
