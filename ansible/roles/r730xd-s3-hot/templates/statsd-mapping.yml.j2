# Managed by Ansible — r730xd-s3-hot role
# statsd_exporter mapping for versitygw StatsD metrics.
#
# versitygw emits metrics over StatsD (--metrics-statsd-servers); it has no
# native Prometheus endpoint, so statsd_exporter bridges StatsD → Prometheus
# (docs/runbooks/versitygw-cli.md). versitygw emits well-labelled counters —
# versitygw_{bytes_read,bytes_written,success_count,failed_count,
# object_created_count,object_removed_count} with action/api/bucket/method/status
# labels — and no timers, so this pass-through is sufficient: statsd_exporter
# carries the names and labels straight through, no per-metric mapping needed.
# (Names observable at `curl <host>:{{ s3_hot_metrics_port }}/metrics`.)
defaults:
  timer_type: histogram
  buckets: [0.005, 0.01, 0.025, 0.05, 0.1, 0.25, 0.5, 1, 2.5, 5, 10]
mappings: []
