# Managed by Ansible — r730xd-s3-hot role. Mode 0600, no_log. Secrets only:
# root account creds + the OpenBao AppRole that versitygw uses to reach its
# Vault-IAM store. Kept in an env_file (not the compose body / argv) so they
# stay off the process command line and out of the world-readable compose file.
ROOT_ACCESS_KEY={{ s3_hot_root_access_key }}
ROOT_SECRET_KEY={{ s3_hot_root_secret_key }}
VGW_IAM_VAULT_ROLE_ID={{ versitygw_iam_role_id }}
VGW_IAM_VAULT_ROLE_SECRET={{ versitygw_iam_role_secret }}
